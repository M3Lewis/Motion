<Window x:Class="Motion.Windows.ScribbleControlWPF"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Scribble" Height="620" Width="420"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5" FontFamily="Segoe UI">
    <Window.Resources>
    <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/Motion;component/Button/MotionButtonStyles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        
        <Style x:Key="MultiLineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="NaN"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 选项区域 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,15" LastChildFill="True">
            <Label Content="Scribble Type:" DockPanel.Dock="Left" FontWeight="SemiBold"/>
            <ComboBox x:Name="ScribbleTypeComboBox" Width="200" HorizontalAlignment="Right" SelectionChanged="ScribbleTypeComboBox_SelectionChanged">
                <ComboBoxItem Content="Custom Text" Tag="text"/>
                <ComboBoxItem Content="Current Time" Tag="time"/>
            </ComboBox>
        </DockPanel>

        <!-- 文本设置区域 -->
        <GroupBox Grid.Row="1" Header="Text Settings">
            <StackPanel>
                <TextBox x:Name="TextContentBox" Text="Hello!" Margin="0,4,0,12" Height="80"
                         Style="{StaticResource MultiLineTextBoxStyle}"/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Text Size:"/>
                    <TextBox x:Name="TextSizeBox" Grid.Column="1" Text="100" Width="80" HorizontalAlignment="Right"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Font:"/>
                    <ComboBox x:Name="FontComboBox" Grid.Column="1" Width="200" HorizontalAlignment="Right"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Font Style:"/>
                    <ComboBox x:Name="FontStyleComboBox" Grid.Column="1" Width="120" HorizontalAlignment="Right">
                        <ComboBoxItem Content="Regular" Tag="0"/>
                        <ComboBoxItem Content="Bold" Tag="1"/>
                        <ComboBoxItem Content="Italic" Tag="2"/>
                        <ComboBoxItem Content="Underline" Tag="4"/>
                        <ComboBoxItem Content="Strikeout" Tag="8"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Max Chars Per Line:" ToolTip="需要字符之间有空格才可以正常换行"/>
                    <TextBox x:Name="MaxCharsBox" Grid.Column="1" Text="100" Width="80" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <!-- 预览区域 -->
        <GroupBox Grid.Row="2" Header="Text Preview">
            <Border Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="PreviewText" Margin="10" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
        </GroupBox>

        <!-- 按钮区域 -->
        <Grid Grid.Row="3" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="Clear" Width="80" Click="ClearButton_Click"/>
            <Button Grid.Column="3" Content="Create" Width="80" Click="CreateButton_Click" Background="#0078D7" Foreground="White" BorderBrush="#005A9E">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1084E3"/>
                                <Setter Property="BorderBrush" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>