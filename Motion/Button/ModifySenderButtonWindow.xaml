<Window x:Class="Motion.UI.ModifySliderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modify Sender" Height="810" Width="780"
        MinHeight="560" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5" FontFamily="Segoe UI">
    <Window.Resources>
    <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/Motion;component/Button/MotionButtonStyles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Grid.Column="0" Header="新建 Sender" Margin="0,0,0,12">
            <StackPanel Margin="8,6,8,8">
                <TextBlock Text="输入数值 (用逗号分隔):" Margin="0,0,0,4"/>
                <TextBox x:Name="NewSliderValues"
                         ToolTip="例如: 0,100,200,350"/>
                <CheckBox x:Name="AllCombinations" Content="生成所有可能的区间组合" Margin="0,8,0,4"/>
                <CheckBox x:Name="NoOverlap" Content="生成不重叠的区间"/>
                <Button Content="新建" Click="CreateSenders_Click" Margin="0,8,0,0"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="0" Header="替换/插入 Sender 区间" Margin="0,0,0,12">
            <StackPanel Margin="8,6,8,8">
                <TextBlock Text="格式: 区间1,区间2 或 区间1,[插入长度],区间2"
                           Margin="0,0,0,4" TextWrapping="Wrap" FontSize="11" Foreground="#888888"/>
                <TextBox x:Name="ReplaceValues"
                         IsEnabled="{Binding HasSelectedSenders}"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="替换"
                            Click="ReplaceRanges_Click"
                            Margin="0"
                            IsEnabled="{Binding HasSelectedSenders}"/>
                    <Button Grid.Column="2" Content="插入"
                            Click="InsertRange_Click"
                            Margin="0"
                            IsEnabled="{Binding HasSelectedSenders}"/>
                </Grid>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Grid.Column="0" Header="合并" Margin="0,0,0,12">
            <Grid Margin="8,6,8,8">
                <Button Content="合并所选 Sender" Click="MergeSenders_Click" Margin="0,4"
                        IsEnabled="{Binding HasSelectedSenders}"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Grid.Column="0" Header="删除">
            <Grid Margin="8,6,8,8">
                <Button Content="删除并调整后续区间"
                        Foreground="#D32F2F"
                        Click="DeleteAndAdjust_Click"
                        Margin="0,4"
                        IsEnabled="{Binding HasSelectedSenders}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFEBEE"/>
                                    <Setter Property="BorderBrush" Value="#E57373"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#FFCDD2"/>
                                    <Setter Property="BorderBrush" Value="#D32F2F"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="0" Grid.Column="2" Header="创建偏移 Sender" Margin="0,0,0,12">
            <StackPanel Margin="8,6,8,8">
                <TextBlock Text="偏移帧数:"/>
                <TextBox x:Name="OffsetFrames"
                         ToolTip="输入要偏移的帧数值"
                         IsEnabled="{Binding HasSingleSenderSelected}"/>
                <Button Content="新建偏移" Click="CreateOffsetSender_Click" Margin="0,8,0,0"
                        IsEnabled="{Binding HasSingleSenderSelected}"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="2" Header="增减区间" Margin="0,0,0,12">
            <StackPanel Margin="8,6,8,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="最小值增减:"/>
                        <TextBox x:Name="MinValueAdjustment"
                                 IsEnabled="{Binding HasSelectedSenders}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="最大值增减:"/>
                        <TextBox x:Name="MaxValueAdjustment"
                                 IsEnabled="{Binding HasSelectedSenders}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="循环次数:" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" x:Name="LoopCount"
                             Text="1"
                             ToolTip="输入调整区间的循环次数（默认为1）"
                             IsEnabled="{Binding HasSelectedSenders}"/>
                </Grid>

                <Grid Margin="0,8,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="修改当前"
                            Click="AdjustRangesExisting_Click"
                            Margin="0"
                            IsEnabled="{Binding HasSelectedSenders}"/>
                    <Button Grid.Column="2" Content="新建"
                            Click="AdjustRangesNew_Click"
                            Margin="0"
                            IsEnabled="{Binding HasSelectedSenders}"/>
                </Grid>

                <CheckBox x:Name="AdjustFollowingSenders"
                          Content="同步偏移后续Sender"
                          ToolTip="当调整某个Sender的区间最大值时，自动偏移其后所有Sender的区间"
                          Margin="0,8,0,4"/>
                <CheckBox x:Name="AdjustAdjacentSenders"
                          Content="同步调整相邻Sender区间值"
                          ToolTip="当调整Sender的区间值时，自动调整相邻Sender的区间值"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Grid.Column="2" Header="拆分">
            <StackPanel Margin="8,6,8,8">
                <TextBlock Text="拆分数值:" Margin="0,0,0,4"/>
                <TextBox x:Name="SplitValues"
                         IsEnabled="{Binding HasSingleSenderSelected}"/>
                <CheckBox x:Name="SplitAllCombinations" Content="生成所有可能的区间组合"
                          Margin="0,8,0,4" IsEnabled="{Binding HasSingleSenderSelected}"/>
                <CheckBox x:Name="SplitNoOverlap" Content="生成不重叠的区间"
                          IsEnabled="{Binding HasSingleSenderSelected}"/>
                <Button Content="拆分" Click="SplitSender_Click" Margin="0,8,0,0"
                        IsEnabled="{Binding HasSingleSenderSelected}"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
