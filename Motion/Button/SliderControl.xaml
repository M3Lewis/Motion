<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Slider Controller" Width="300" Height="200"
        x:Class="Motion.Toolbar.SliderControlWPF"
        Topmost="True"
        xmlns:local="clr-namespace:Motion.Toolbar"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5" FontFamily="Segoe UI">

    <Window.Resources>
    <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/Motion;component/Button/MotionButtonStyles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        <Style x:Key="AutoUpdateButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D1D1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5F1FB"/>
                                <Setter Property="BorderBrush" Value="#0078D7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CCE4F7"/>
                                <Setter Property="BorderBrush" Value="#005499"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter Property="Background" Value="#90CAF9"/>
                                <Setter Property="BorderBrush" Value="#1976D2"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Slider x:Name="slider"
                Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TickFrequency="1"
                IsSnapToTickEnabled="True"
                Margin="0,5,0,15"
                Grid.Row="0"
                Grid.ColumnSpan="2"/>

        <TextBox x:Name="valueTextBox"
                Text="{Binding Value, StringFormat={}{0:F0}, UpdateSourceTrigger=LostFocus}"
                Grid.Row="1"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Center"
                Width="80"
                TextAlignment="Center"
                Margin="0,0,0,15"
                FontWeight="SemiBold"
                FontSize="14"
                PreviewTextInput="NumberValidationTextBox"
                KeyDown="ValueTextBox_KeyDown"
                LostFocus="ValueTextBox_LostFocus"/>

        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="minusButton"
                    Content="-"
                    Click="MinusButton_Click"
                    MouseRightButtonDown="MinusButton_Click"
                    Style="{StaticResource AutoUpdateButtonStyle}"
                    Height="32"
                    Grid.Column="0">
                <Button.ToolTip>
                    <ToolTip>
                        <TextBlock>
                            <Run FontWeight="Bold">左键点击:</Run> 减少1帧<LineBreak/>
                            <Run FontWeight="Bold">右键点击:</Run> 开始/停止自动递减
                        </TextBlock>
                    </ToolTip>
                </Button.ToolTip>
            </Button>
            <Button x:Name="plusButton"
                    Content="+"
                    Click="PlusButton_Click"
                    MouseRightButtonDown="PlusButton_Click"
                    Style="{StaticResource AutoUpdateButtonStyle}"
                    Height="32"
                    Grid.Column="2">
                <Button.ToolTip>
                    <ToolTip>
                        <TextBlock>
                            <Run FontWeight="Bold">左键点击:</Run> 增加1帧<LineBreak/>
                            <Run FontWeight="Bold">右键点击:</Run> 开始/停止自动递增
                        </TextBlock>
                    </ToolTip>
                </Button.ToolTip>
            </Button>
        </Grid>

        <Grid Grid.Row="3" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="minButton"
                    Content="MIN"
                    Click="MinButton_Click"
                   
                    Grid.Column="0"/>
            <Button x:Name="maxButton"
                    Content="MAX"
                    Click="MaxButton_Click"
                   
                    Grid.Column="2"/>
        </Grid>
    </Grid>
</Window>