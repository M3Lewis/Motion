<Window x:Class="Motion.Views.RangeSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Range" Height="150" Width="300"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F5F5" FontFamily="Segoe UI">
    <Window.Resources>
    <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/Motion;component/Button/MotionButtonStyles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Time Interval:" Margin="0,0,0,8" Foreground="#444444"/>
            <ComboBox x:Name="TimeIntervalComboBox"
                      SelectionChanged="TimeIntervalComboBox_SelectionChanged"/>
        </StackPanel>

        <Button Grid.Row="2" Content="OK" Width="80"
                HorizontalAlignment="Right" Click="OkButton_Click"/>
    </Grid>
</Window>